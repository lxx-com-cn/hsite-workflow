<?xml version="1.0" encoding="UTF-8"?>
<sc:Package xmlns:sc="http://www.example.com/service-choreography" id="org-structure-2sub-user" name="双Sub流程混合人工任务" version="3.2.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.example.com/service-choreography workflow-v10.xsd">
	<!-- ==================== 主流程 ==================== -->
	<sc:Workflow id="main-2sub-user-process" name="主流程-双Sub人工任务" version="3.2.0" type="MAIN" contractMode="STRICT">
		<sc:Parameters>
			<sc:Parameter name="deptRequest" type="bean" className="com.hbs.site.module.system.controller.admin.dept.vo.dept.DeptSaveReqVO" direction="IN" required="true"/>
			<sc:Parameter name="postRequest" type="bean" className="com.hbs.site.module.system.controller.admin.dept.vo.post.PostSaveReqVO" direction="IN" required="true"/>
			<sc:Parameter name="userRequest" type="bean" className="com.hbs.site.module.system.controller.admin.user.vo.user.UserSaveReqVO" direction="IN" required="true"/>
			<sc:Parameter name="deptId" type="long" direction="OUT"/>
			<sc:Parameter name="postResult" type="bean" className="java.util.HashMap" direction="OUT"/>
			<sc:Parameter name="userResult" type="bean" className="java.util.HashMap" direction="OUT"/>
		</sc:Parameters>
		<sc:Activities>
			<!-- 开始事件 -->
			<sc:Activity id="main-start" name="主流程开始" type="START_EVENT">
				<sc:StartEvent/>
			</sc:Activity>
			<!-- 自动任务1：创建部门 -->
			<sc:Activity id="main-createDept" name="创建部门" type="AUTO_TASK">
				<sc:AutoTask>
					<sc:SpringBean beanName="deptService" method="createDept"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#deptRequest" target="#deptRequest" dataType="bean"/>
						<sc:Output source="#result" target="#deptId" dataType="long"/>
					</sc:DataMapping>
				</sc:AutoTask>
			</sc:Activity>
			<!-- 子流程1：岗位处理（含人工审批） -->
			<sc:Activity id="main-subPost" name="调用子流程-岗位处理" type="SUB_PROCESS">
				<sc:SubProcess>
					<sc:WorkflowRef packageId="org-structure-2sub-user" workflowId="sub-post-process" version="3.2.0"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#deptId" target="#deptId" dataType="long"/>
						<sc:Input source="#postRequest" target="#postRequest" dataType="bean"/>
						<sc:Output source="#subResult.postId" target="#postId" dataType="long"/>
						<sc:Output source="#subResult.postId" target="#postResult.postId" dataType="long"/>
						<sc:Output source="#subResult.postDetail" target="#postResult.postDetail" dataType="bean"/>
					</sc:DataMapping>
					<sc:ExecutionStrategy mode="SYNC" timeout="60000"/>
				</sc:SubProcess>
			</sc:Activity>
			<!-- 子流程2：用户处理（含人工审批） -->
			<sc:Activity id="main-subUser" name="调用子流程-用户处理" type="SUB_PROCESS">
				<sc:SubProcess>
					<sc:WorkflowRef packageId="org-structure-2sub-user" workflowId="sub-user-process" version="3.2.0"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#deptId" target="#deptId" dataType="long"/>
						<sc:Input source="#postId" target="#postId" dataType="long"/>
						<sc:Input source="#userRequest" target="#userRequest" dataType="bean"/>
						<sc:Output source="#subResult.userId" target="#userId" dataType="long"/>
						<sc:Output source="#subResult.userId" target="#userResult.userId" dataType="long"/>
						<sc:Output source="#subResult.userDetail" target="#userResult.userDetail" dataType="bean"/>
					</sc:DataMapping>
					<sc:ExecutionStrategy mode="SYNC" timeout="60000"/>
				</sc:SubProcess>
			</sc:Activity>
			<!-- 自动任务2：查询岗位详情（复用子流程输出的postId） -->
			<sc:Activity id="main-queryPost" name="查询岗位详情" type="AUTO_TASK">
				<sc:AutoTask>
					<sc:SpringBean beanName="postService" method="getPost"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#postId" target="#postId" dataType="long"/>
						<sc:Output source="#result" target="#postResult.postDetail" dataType="bean"/>
					</sc:DataMapping>
				</sc:AutoTask>
			</sc:Activity>
			<!-- 自动任务3：查询用户详情 -->
			<sc:Activity id="main-queryUser" name="查询用户详情" type="AUTO_TASK">
				<sc:AutoTask>
					<sc:SpringBean beanName="adminUserService" method="getUser"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#userId" target="#userId" dataType="long"/>
						<sc:Output source="#result" target="#userResult.userDetail" dataType="bean"/>
					</sc:DataMapping>
				</sc:AutoTask>
			</sc:Activity>
			<!-- 结束事件：汇总结果 -->
			<sc:Activity id="main-end" name="主流程结束" type="END_EVENT">
				<sc:EndEvent>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Output source="#deptId" target="#finalReport.deptId" dataType="long"/>
						<sc:Output source="#postResult" target="#finalReport.postResult" dataType="bean"/>
						<sc:Output source="#userResult" target="#finalReport.userResult" dataType="bean"/>
					</sc:DataMapping>
				</sc:EndEvent>
			</sc:Activity>
		</sc:Activities>
		<sc:Transitions>
			<sc:Transition id="t1" from="main-start" to="main-createDept"/>
			<sc:Transition id="t2" from="main-createDept" to="main-subPost"/>
			<sc:Transition id="t3" from="main-subPost" to="main-subUser"/>
			<sc:Transition id="t4" from="main-subUser" to="main-queryPost"/>
			<sc:Transition id="t5" from="main-queryPost" to="main-queryUser"/>
			<sc:Transition id="t6" from="main-queryUser" to="main-end"/>
		</sc:Transitions>
	</sc:Workflow>
	<!-- ==================== 子流程1：岗位处理（含人工审批） ==================== -->
	<sc:Workflow id="sub-post-process" name="子流程-岗位处理" version="3.2.0" type="SUB" contractMode="STRICT">
		<sc:Parameters>
			<sc:Parameter name="deptId" type="long" direction="IN" required="true"/>
			<sc:Parameter name="postRequest" type="bean" className="com.hbs.site.module.system.controller.admin.dept.vo.post.PostSaveReqVO" direction="IN" required="true"/>
			<sc:Parameter name="subResult" type="bean" className="java.util.HashMap" direction="OUT"/>
		</sc:Parameters>
		<sc:Activities>
			<sc:Activity id="subPost-start" name="岗位子流程开始" type="START_EVENT">
				<sc:StartEvent/>
			</sc:Activity>
			<!-- 人工任务：岗位审批 -->
			<sc:Activity id="postApprove" name="岗位审批" type="USER_TASK">
				<sc:UserTask category="审批" urgency="NORMAL">
					<sc:Assignment strategy="FIXED">
						<sc:User>post_approver_001</sc:User>
					</sc:Assignment>
					<sc:CompletionRule type="ANY"/>
					<sc:Form>
						<sc:Field name="approveResult" type="radio" label="审批结果" required="true" options="AGREE:同意,REJECT:驳回"/>
						<sc:Field name="comment" type="textarea" label="审批意见"/>
					</sc:Form>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Output source="#formData.approveResult" target="#postApproveResult" dataType="string"/>
						<sc:Output source="#formData.comment" target="#postComment" dataType="string"/>
					</sc:DataMapping>
					<sc:ExtendedOperation allowTransfer="true" allowBack="false" allowUrge="true"/>
				</sc:UserTask>
			</sc:Activity>
			<!-- 排他网关：判断审批结果 -->
			<sc:Activity id="postGateway" name="岗位审批判断" type="EXCLUSIVE_GATEWAY">
				<sc:Gateway mode="SPLIT"/>
			</sc:Activity>
			<!-- 创建岗位（同意分支） -->
			<sc:Activity id="subPost-create" name="创建岗位" type="AUTO_TASK">
				<sc:AutoTask>
					<sc:SpringBean beanName="postService" method="createPost"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#postRequest" target="#postRequest" dataType="bean"/>
						<sc:Output source="#result" target="#postId" dataType="long"/>
					</sc:DataMapping>
				</sc:AutoTask>
			</sc:Activity>
			<!-- 查询岗位详情（同意分支） -->
			<sc:Activity id="subPost-query" name="查询岗位详情" type="AUTO_TASK">
				<sc:AutoTask>
					<sc:SpringBean beanName="postService" method="getPost"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#postId" target="#postId" dataType="long"/>
						<sc:Output source="#result" target="#subResult.postDetail" dataType="bean"/>
					</sc:DataMapping>
				</sc:AutoTask>
			</sc:Activity>
			<!-- 结束事件（同意分支） -->
			<sc:Activity id="subPost-end" name="岗位子流程结束" type="END_EVENT">
				<sc:EndEvent>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Output source="#postId" target="#subResult.postId" dataType="long"/>
						<sc:Output source="'岗位创建成功'" target="#subResult.message" dataType="string"/>
					</sc:DataMapping>
				</sc:EndEvent>
			</sc:Activity>
			<!-- 驳回结束事件 -->
			<sc:Activity id="subPost-endReject" name="岗位子流程驳回结束" type="END_EVENT">
				<sc:EndEvent type="terminate">
					<sc:DataMapping scope="WORKFLOW">
						<sc:Output source="'REJECTED'" target="#postApproveResult" dataType="string"/>
					</sc:DataMapping>
				</sc:EndEvent>
			</sc:Activity>
		</sc:Activities>
		<sc:Transitions>
			<sc:Transition id="sp1" from="subPost-start" to="postApprove"/>
			<sc:Transition id="sp2" from="postApprove" to="postGateway"/>
			<sc:Transition id="sp3" from="postGateway" to="subPost-create" condition="#postApproveResult == 'AGREE'"/>
			<sc:Transition id="sp4" from="postGateway" to="subPost-endReject" condition="#postApproveResult == 'REJECT'"/>
			<sc:Transition id="sp5" from="subPost-create" to="subPost-query"/>
			<sc:Transition id="sp6" from="subPost-query" to="subPost-end"/>
		</sc:Transitions>
	</sc:Workflow>
	<!-- ==================== 子流程2：用户处理（含人工审批） ==================== -->
	<sc:Workflow id="sub-user-process" name="子流程-用户处理" version="3.2.0" type="SUB" contractMode="STRICT">
		<sc:Parameters>
			<sc:Parameter name="deptId" type="long" direction="IN" required="true"/>
			<sc:Parameter name="postId" type="long" direction="IN" required="true"/>
			<sc:Parameter name="userRequest" type="bean" className="com.hbs.site.module.system.controller.admin.user.vo.user.UserSaveReqVO" direction="IN" required="true"/>
			<sc:Parameter name="subResult" type="bean" className="java.util.HashMap" direction="OUT"/>
		</sc:Parameters>
		<sc:Activities>
			<sc:Activity id="subUser-start" name="用户子流程开始" type="START_EVENT">
				<sc:StartEvent/>
			</sc:Activity>
			<!-- 人工任务：用户审批 -->
			<sc:Activity id="userApprove" name="用户审批" type="USER_TASK">
				<sc:UserTask category="审批" urgency="NORMAL">
					<sc:Assignment strategy="FIXED">
						<sc:User>user_approver_001</sc:User>
					</sc:Assignment>
					<sc:CompletionRule type="ANY"/>
					<sc:Form>
						<sc:Field name="approveResult" type="radio" label="审批结果" required="true" options="AGREE:同意,REJECT:驳回"/>
						<sc:Field name="comment" type="textarea" label="审批意见"/>
					</sc:Form>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Output source="#formData.approveResult" target="#userApproveResult" dataType="string"/>
						<sc:Output source="#formData.comment" target="#userComment" dataType="string"/>
					</sc:DataMapping>
					<sc:ExtendedOperation allowTransfer="true" allowBack="false" allowUrge="true"/>
				</sc:UserTask>
			</sc:Activity>
			<!-- 排他网关 -->
			<sc:Activity id="userGateway" name="用户审批判断" type="EXCLUSIVE_GATEWAY">
				<sc:Gateway mode="SPLIT"/>
			</sc:Activity>
			<!-- 创建用户（同意分支） -->
			<sc:Activity id="subUser-create" name="创建用户" type="AUTO_TASK">
				<sc:AutoTask>
					<sc:SpringBean beanName="adminUserService" method="createUser"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#deptId" target="#userRequest.deptId" dataType="long"/>
						<sc:Input source="#postId" target="#userRequest.postIds" dataType="set" beanClass="java.lang.Long"/>
						<sc:Input source="#userRequest" target="#userRequest" dataType="bean"/>
						<sc:Output source="#result" target="#userId" dataType="long"/>
					</sc:DataMapping>
				</sc:AutoTask>
			</sc:Activity>
			<!-- 查询用户详情 -->
			<sc:Activity id="subUser-query" name="查询用户详情" type="AUTO_TASK">
				<sc:AutoTask>
					<sc:SpringBean beanName="adminUserService" method="getUser"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#userId" target="#userId" dataType="long"/>
						<sc:Output source="#result" target="#subResult.userDetail" dataType="bean"/>
					</sc:DataMapping>
				</sc:AutoTask>
			</sc:Activity>
			<!-- 结束事件（同意分支） -->
			<sc:Activity id="subUser-end" name="用户子流程结束" type="END_EVENT">
				<sc:EndEvent>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Output source="#userId" target="#subResult.userId" dataType="long"/>
						<sc:Output source="'用户创建成功'" target="#subResult.message" dataType="string"/>
					</sc:DataMapping>
				</sc:EndEvent>
			</sc:Activity>
			<!-- 驳回结束事件 -->
			<sc:Activity id="subUser-endReject" name="用户子流程驳回结束" type="END_EVENT">
				<sc:EndEvent type="terminate">
					<sc:DataMapping scope="WORKFLOW">
						<sc:Output source="'REJECTED'" target="#userApproveResult" dataType="string"/>
					</sc:DataMapping>
				</sc:EndEvent>
			</sc:Activity>
		</sc:Activities>
		<sc:Transitions>
			<sc:Transition id="su1" from="subUser-start" to="userApprove"/>
			<sc:Transition id="su2" from="userApprove" to="userGateway"/>
			<sc:Transition id="su3" from="userGateway" to="subUser-create" condition="#userApproveResult == 'AGREE'"/>
			<sc:Transition id="su4" from="userGateway" to="subUser-endReject" condition="#userApproveResult == 'REJECT'"/>
			<sc:Transition id="su5" from="subUser-create" to="subUser-query"/>
			<sc:Transition id="su6" from="subUser-query" to="subUser-end"/>
		</sc:Transitions>
	</sc:Workflow>
</sc:Package>
