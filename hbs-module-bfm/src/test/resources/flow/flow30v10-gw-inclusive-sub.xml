<?xml version="1.0" encoding="UTF-8"?>
<sc:Package xmlns:sc="http://www.example.com/service-choreography"
            id="inclusive-sub-demo"
            name="包容网关父子流程示例"
            version="1.0.0"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="http://www.example.com/service-choreography workflow-v10.xsd">

    <!-- ==================== 主流程 ==================== -->
    <sc:Workflow id="inclusive-main" name="主流程-包容网关" version="1.0.0" type="MAIN" contractMode="STRICT">
        <sc:Parameters>
            <sc:Parameter name="flags" type="string" direction="IN" required="true"/>
            <sc:Parameter name="deptRequest" type="bean" className="com.hbs.site.module.system.controller.admin.dept.vo.dept.DeptSaveReqVO" direction="IN" required="false"/>
            <sc:Parameter name="postRequest" type="bean" className="com.hbs.site.module.system.controller.admin.dept.vo.post.PostSaveReqVO" direction="IN" required="false"/>
            <sc:Parameter name="userRequest" type="bean" className="com.hbs.site.module.system.controller.admin.user.vo.user.UserSaveReqVO" direction="IN" required="false"/>
            <sc:Parameter name="subFlags" type="string" direction="IN" required="true"/>
            <sc:Parameter name="result" type="bean" className="java.util.HashMap" direction="OUT"/>
        </sc:Parameters>

        <sc:Activities>
            <sc:Activity id="main-start" name="主流程开始" type="START_EVENT">
                <sc:StartEvent/>
            </sc:Activity>

            <!-- 主流程包容网关 SPLIT -->
            <sc:Activity id="main-SPLIT" name="主流程分支开始" type="INCLUSIVE_GATEWAY">
                <sc:Gateway mode="SPLIT"/>
            </sc:Activity>

            <sc:Activity id="main-createDept" name="创建部门" type="AUTO_TASK">
                <sc:AutoTask>
                    <sc:SpringBean beanName="deptService" method="createDept"/>
                    <sc:DataMapping scope="WORKFLOW">
                        <sc:Input source="#deptRequest" target="#deptRequest" dataType="bean" required="true"/>
                        <sc:Output source="#result" target="#deptId"/>
                    </sc:DataMapping>
                </sc:AutoTask>
            </sc:Activity>

            <sc:Activity id="main-createPost" name="创建岗位" type="AUTO_TASK">
                <sc:AutoTask>
                    <sc:SpringBean beanName="postService" method="createPost"/>
                    <sc:DataMapping scope="WORKFLOW">
                        <sc:Input source="#postRequest" target="#postRequest" dataType="bean" required="true"/>
                        <sc:Output source="#result" target="#postId"/>
                    </sc:DataMapping>
                </sc:AutoTask>
            </sc:Activity>

            <sc:Activity id="main-createUser" name="创建用户" type="AUTO_TASK">
                <sc:AutoTask>
                    <sc:SpringBean beanName="adminUserService" method="createUser"/>
                    <sc:DataMapping scope="WORKFLOW">
                        <sc:Input source="#userRequest" target="#userRequest" dataType="bean" required="true"/>
                        <sc:Output source="#result" target="#userId"/>
                    </sc:DataMapping>
                </sc:AutoTask>
            </sc:Activity>

            <sc:Activity id="main-default" name="主流程默认分支" type="AUTO_TASK">
                <sc:AutoTask>
                    <sc:JavaBean class="java.lang.String" method="valueOf" static="true"/>
                    <sc:DataMapping scope="WORKFLOW">
                        <sc:Input source="'MAIN_DEFAULT'" target="#arg0"/>
                        <sc:Output source="#result" target="#mainDefaultFlag"/>
                    </sc:DataMapping>
                </sc:AutoTask>
            </sc:Activity>

            <!-- 主流程包容网关 JOIN -->
            <sc:Activity id="main-JOIN" name="主流程分支汇聚" type="INCLUSIVE_GATEWAY">
                <sc:Gateway mode="JOIN"/>
            </sc:Activity>

            <!-- 调用子流程，直接使用 subFlags -->
            <sc:Activity id="main-subProcess" name="调用子流程" type="SUB_PROCESS">
                <sc:SubProcess>
                    <sc:WorkflowRef packageId="inclusive-sub-demo" workflowId="inclusive-sub" version="1.0.0"/>
                    <sc:DataMapping scope="WORKFLOW">
                        <sc:Input source="#subFlags" target="#subFlagsParam" dataType="string"/>
                        <sc:Input source="#deptId" target="#deptId" dataType="long"/>
                        <sc:Input source="#postId" target="#postId" dataType="long"/>
                        <sc:Input source="#userId" target="#userId" dataType="long"/>
                        <sc:Output source="#subResult.subA" target="#subA"/>
                        <sc:Output source="#subResult.subB" target="#subB"/>
                        <sc:Output source="#subResult.subC" target="#subC"/>
                        <sc:Output source="#subResult.subDefault" target="#subDefault"/>
                    </sc:DataMapping>
                    <sc:ExecutionStrategy mode="SYNC" timeout="30000"/>
                </sc:SubProcess>
            </sc:Activity>

            <sc:Activity id="main-end" name="主流程结束" type="END_EVENT">
                <sc:EndEvent>
                    <sc:DataMapping scope="WORKFLOW">
                        <sc:Output source="#deptId != null ? 'A' : null" target="#result.mainA"/>
                        <sc:Output source="#postId != null ? 'B' : null" target="#result.mainB"/>
                        <sc:Output source="#userId != null ? 'C' : null" target="#result.mainC"/>
                        <sc:Output source="#mainDefaultFlag != null ? 'D' : null" target="#result.mainD"/>
                        <sc:Output source="#subA != null ? 'A' : null" target="#result.subA"/>
                        <sc:Output source="#subB != null ? 'B' : null" target="#result.subB"/>
                        <sc:Output source="#subC != null ? 'C' : null" target="#result.subC"/>
                        <sc:Output source="#subDefault != null ? 'D' : null" target="#result.subD"/>
                        <sc:Output source="#deptId" target="#result.deptId"/>
                        <sc:Output source="#postId" target="#result.postId"/>
                        <sc:Output source="#userId" target="#result.userId"/>
                    </sc:DataMapping>
                </sc:EndEvent>
            </sc:Activity>
        </sc:Activities>

        <sc:Transitions>
            <sc:Transition id="t-start-split" from="main-start" to="main-SPLIT"/>

            <sc:Transition id="t-split-dept" from="main-SPLIT" to="main-createDept" condition="#flags.contains('A')" priority="10"/>
            <sc:Transition id="t-split-post" from="main-SPLIT" to="main-createPost" condition="#flags.contains('B')" priority="9"/>
            <sc:Transition id="t-split-user" from="main-SPLIT" to="main-createUser" condition="#flags.contains('C')" priority="8"/>
            <sc:Transition id="t-split-default" from="main-SPLIT" to="main-default" default="true" priority="1"/>

            <sc:Transition id="t-dept-join" from="main-createDept" to="main-JOIN"/>
            <sc:Transition id="t-post-join" from="main-createPost" to="main-JOIN"/>
            <sc:Transition id="t-user-join" from="main-createUser" to="main-JOIN"/>
            <sc:Transition id="t-default-join" from="main-default" to="main-JOIN"/>

            <sc:Transition id="t-join-sub" from="main-JOIN" to="main-subProcess"/>
            <sc:Transition id="t-sub-end" from="main-subProcess" to="main-end"/>
        </sc:Transitions>
    </sc:Workflow>

    <!-- ==================== 子流程 ==================== -->
    <sc:Workflow id="inclusive-sub" name="子流程-包容网关" version="1.0.0" type="SUB" contractMode="STRICT">
        <sc:Parameters>
            <sc:Parameter name="subFlagsParam" type="string" direction="IN" required="true"/>
            <sc:Parameter name="deptId" type="long" direction="IN" required="false"/>
            <sc:Parameter name="postId" type="long" direction="IN" required="false"/>
            <sc:Parameter name="userId" type="long" direction="IN" required="false"/>
            <sc:Parameter name="subResult" type="bean" className="java.util.HashMap" direction="OUT"/>
        </sc:Parameters>

        <sc:Activities>
            <sc:Activity id="sub-start" name="子流程开始" type="START_EVENT">
                <sc:StartEvent/>
            </sc:Activity>

            <!-- 子流程包容网关 SPLIT -->
            <sc:Activity id="sub-SPLIT" name="子流程分支开始" type="INCLUSIVE_GATEWAY">
                <sc:Gateway mode="SPLIT"/>
            </sc:Activity>

            <sc:Activity id="sub-log" name="记录日志" type="AUTO_TASK">
                <sc:AutoTask>
                    <sc:JavaBean class="java.lang.String" method="valueOf" static="true"/>
                    <sc:DataMapping scope="WORKFLOW">
                        <sc:Input source="'LOG_EXECUTED'" target="#arg0"/>
                        <sc:Output source="#result" target="#subA"/>
                    </sc:DataMapping>
                </sc:AutoTask>
            </sc:Activity>

            <sc:Activity id="sub-notify" name="发送通知" type="AUTO_TASK">
                <sc:AutoTask>
                    <sc:JavaBean class="java.lang.String" method="valueOf" static="true"/>
                    <sc:DataMapping scope="WORKFLOW">
                        <sc:Input source="'NOTIFY_EXECUTED'" target="#arg0"/>
                        <sc:Output source="#result" target="#subB"/>
                    </sc:DataMapping>
                </sc:AutoTask>
            </sc:Activity>

            <sc:Activity id="sub-cache" name="更新缓存" type="AUTO_TASK">
                <sc:AutoTask>
                    <sc:JavaBean class="java.lang.String" method="valueOf" static="true"/>
                    <sc:DataMapping scope="WORKFLOW">
                        <sc:Input source="'CACHE_EXECUTED'" target="#arg0"/>
                        <sc:Output source="#result" target="#subC"/>
                    </sc:DataMapping>
                </sc:AutoTask>
            </sc:Activity>

            <sc:Activity id="sub-default" name="子流程默认分支" type="AUTO_TASK">
                <sc:AutoTask>
                    <sc:JavaBean class="java.lang.String" method="valueOf" static="true"/>
                    <sc:DataMapping scope="WORKFLOW">
                        <sc:Input source="'SUB_DEFAULT'" target="#arg0"/>
                        <sc:Output source="#result" target="#subDefault"/>
                    </sc:DataMapping>
                </sc:AutoTask>
            </sc:Activity>

            <!-- 子流程包容网关 JOIN -->
            <sc:Activity id="sub-JOIN" name="子流程分支汇聚" type="INCLUSIVE_GATEWAY">
                <sc:Gateway mode="JOIN"/>
            </sc:Activity>

            <sc:Activity id="sub-end" name="子流程结束" type="END_EVENT">
                <sc:EndEvent>
                    <sc:DataMapping scope="WORKFLOW">
                        <sc:Output source="#subA" target="#subResult.subA"/>
                        <sc:Output source="#subB" target="#subResult.subB"/>
                        <sc:Output source="#subC" target="#subResult.subC"/>
                        <sc:Output source="#subDefault" target="#subResult.subDefault"/>
                    </sc:DataMapping>
                </sc:EndEvent>
            </sc:Activity>
        </sc:Activities>

        <sc:Transitions>
            <sc:Transition id="s-start-split" from="sub-start" to="sub-SPLIT"/>

            <sc:Transition id="s-split-log" from="sub-SPLIT" to="sub-log" condition="#subFlagsParam.contains('A')" priority="10"/>
            <sc:Transition id="s-split-notify" from="sub-SPLIT" to="sub-notify" condition="#subFlagsParam.contains('B')" priority="9"/>
            <sc:Transition id="s-split-cache" from="sub-SPLIT" to="sub-cache" condition="#subFlagsParam.contains('C')" priority="8"/>
            <sc:Transition id="s-split-default" from="sub-SPLIT" to="sub-default" default="true" priority="1"/>

            <sc:Transition id="s-log-join" from="sub-log" to="sub-JOIN"/>
            <sc:Transition id="s-notify-join" from="sub-notify" to="sub-JOIN"/>
            <sc:Transition id="s-cache-join" from="sub-cache" to="sub-JOIN"/>
            <sc:Transition id="s-default-join" from="sub-default" to="sub-JOIN"/>

            <sc:Transition id="s-join-end" from="sub-JOIN" to="sub-end"/>
        </sc:Transitions>
    </sc:Workflow>
</sc:Package>