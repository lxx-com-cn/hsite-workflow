<?xml version="1.0" encoding="UTF-8"?>
<sc:Package xmlns:sc="http://www.example.com/service-choreography" id="gw-parallel-sub-demo" name="并行网关父子流程示例" version="1.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.example.com/service-choreography workflow-v10.xsd">
	<!-- 主流程：包含并行网关 -->
	<sc:Workflow id="main-parallel-process" name="主流程-并行网关" version="1.0.0" type="MAIN" contractMode="STRICT">
		<sc:Parameters>
			<!-- 输入参数 -->
			<sc:Parameter name="deptRequest" type="bean" className="com.hbs.site.module.system.controller.admin.dept.vo.dept.DeptSaveReqVO" direction="IN" required="true"/>
			<sc:Parameter name="postRequest" type="bean" className="com.hbs.site.module.system.controller.admin.dept.vo.post.PostSaveReqVO" direction="IN" required="true"/>
			<sc:Parameter name="userRequest" type="bean" className="com.hbs.site.module.system.controller.admin.user.vo.user.UserSaveReqVO" direction="IN" required="true"/>
			<!-- 输出参数 -->
			<sc:Parameter name="result" type="bean" className="java.util.HashMap" direction="OUT"/>
		</sc:Parameters>
		<sc:Activities>
			<!-- 开始事件 -->
			<sc:Activity id="main-start" name="主流程开始" type="START_EVENT">
				<sc:StartEvent/>
			</sc:Activity>
			<!-- 主流程并行网关 SPLIT -->
			<sc:Activity id="main-SPLIT" name="主流程并行分支开始" type="PARALLEL_GATEWAY">
				<sc:Gateway mode="SPLIT"/>
			</sc:Activity>
			<!-- 分支1：创建部门 -->
			<sc:Activity id="main-createDept" name="创建部门" type="AUTO_TASK">
				<sc:AutoTask>
					<sc:SpringBean beanName="deptService" method="createDept"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#deptRequest" target="#deptRequest" dataType="bean"/>
						<sc:Output source="#result" target="#deptId"/>
					</sc:DataMapping>
				</sc:AutoTask>
			</sc:Activity>
			<!-- 分支2：调用子流程（子流程也包含并行网关） -->
			<sc:Activity id="main-subProcess" name="调用子流程" type="SUB_PROCESS">
				<sc:SubProcess>
					<sc:WorkflowRef packageId="gw-parallel-sub-demo" workflowId="sub-parallel-process" version="1.0.0"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#deptId" target="#deptId" dataType="long"/>
						<sc:Input source="#postRequest" target="#postRequest" dataType="bean"/>
						<sc:Input source="#userRequest" target="#userRequest" dataType="bean"/>
						<sc:Output source="#subResult.postId" target="#postId"/>
						<sc:Output source="#subResult.userId" target="#userId"/>
						<sc:Output source="#subResult.postDetail" target="#postDetail"/>
						<sc:Output source="#subResult.userDetail" target="#userDetail"/>
					</sc:DataMapping>
					<sc:ExecutionStrategy mode="SYNC" timeout="30000"/>
				</sc:SubProcess>
			</sc:Activity>
			<!-- 主流程并行网关 JOIN -->
			<sc:Activity id="main-JOIN" name="主流程并行分支汇聚" type="PARALLEL_GATEWAY">
				<sc:Gateway mode="JOIN"/>
			</sc:Activity>
			<!-- 查询部门详情 -->
			<sc:Activity id="main-queryDept" name="查询部门详情" type="AUTO_TASK">
				<sc:AutoTask>
					<sc:SpringBean beanName="deptService" method="getDept"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#deptId" target="#id" dataType="long"/>
						<sc:Output source="#result" target="#deptDetail"/>
					</sc:DataMapping>
				</sc:AutoTask>
			</sc:Activity>
			<!-- 结束事件：构建最终结果 -->
			<sc:Activity id="main-end" name="主流程结束" type="END_EVENT">
				<sc:EndEvent>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Output source="#deptId" target="#result.deptId"/>
						<sc:Output source="#deptDetail" target="#result.deptDetail"/>
						<sc:Output source="#postId" target="#result.postId"/>
						<sc:Output source="#postDetail" target="#result.postDetail"/>
						<sc:Output source="#userId" target="#result.userId"/>
						<sc:Output source="#userDetail" target="#result.userDetail"/>
					</sc:DataMapping>
				</sc:EndEvent>
			</sc:Activity>
		</sc:Activities>
		<sc:Transitions>
			<sc:Transition id="t-start-SPLIT" from="main-start" to="main-SPLIT"/>
			<sc:Transition id="t-SPLIT-createDept" from="main-SPLIT" to="main-createDept"/>
			<sc:Transition id="t-SPLIT-subProcess" from="main-SPLIT" to="main-subProcess"/>
			<sc:Transition id="t-createDept-JOIN" from="main-createDept" to="main-JOIN"/>
			<sc:Transition id="t-subProcess-JOIN" from="main-subProcess" to="main-JOIN"/>
			<sc:Transition id="t-JOIN-queryDept" from="main-JOIN" to="main-queryDept"/>
			<sc:Transition id="t-queryDept-end" from="main-queryDept" to="main-end"/>
		</sc:Transitions>
	</sc:Workflow>
	<!-- 子流程：包含并行网关 -->
	<sc:Workflow id="sub-parallel-process" name="子流程-并行网关" version="1.0.0" type="SUB" contractMode="STRICT">
		<sc:Parameters>
			<sc:Parameter name="deptId" type="long" direction="IN" required="true"/>
			<sc:Parameter name="postRequest" type="bean" className="com.hbs.site.module.system.controller.admin.dept.vo.post.PostSaveReqVO" direction="IN" required="true"/>
			<sc:Parameter name="userRequest" type="bean" className="com.hbs.site.module.system.controller.admin.user.vo.user.UserSaveReqVO" direction="IN" required="true"/>
			<sc:Parameter name="postId" type="long" direction="OUT"/>
			<sc:Parameter name="userId" type="long" direction="OUT"/>
			<sc:Parameter name="subResult" type="bean" className="java.util.HashMap" direction="OUT"/>
		</sc:Parameters>
		<sc:Activities>
			<sc:Activity id="sub-start" name="子流程开始" type="START_EVENT">
				<sc:StartEvent/>
			</sc:Activity>
			<!-- 子流程并行网关 SPLIT -->
			<sc:Activity id="sub-SPLIT" name="子流程并行分支开始" type="PARALLEL_GATEWAY">
				<sc:Gateway mode="SPLIT"/>
			</sc:Activity>
			<!-- 分支1：创建岗位 -->
			<sc:Activity id="sub-createPost" name="创建岗位" type="AUTO_TASK">
				<sc:AutoTask>
					<sc:SpringBean beanName="postService" method="createPost"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#deptId" target="#postRequest.deptId" dataType="long"/>
						<sc:Input source="#postRequest" target="#postRequest" dataType="bean"/>
						<sc:Output source="#result" target="#postId"/>
					</sc:DataMapping>
				</sc:AutoTask>
			</sc:Activity>
			<!-- 分支2：创建用户 -->
			<sc:Activity id="sub-createUser" name="创建用户" type="AUTO_TASK">
				<sc:AutoTask>
					<sc:SpringBean beanName="adminUserService" method="createUser"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#deptId" target="#userRequest.deptId" dataType="long"/>
						<sc:Input source="#userRequest" target="#userRequest" dataType="bean"/>
						<sc:Output source="#result" target="#userId"/>
					</sc:DataMapping>
				</sc:AutoTask>
			</sc:Activity>
			<!-- 子流程并行网关 JOIN -->
			<sc:Activity id="sub-JOIN" name="子流程并行分支汇聚" type="PARALLEL_GATEWAY">
				<sc:Gateway mode="JOIN"/>
			</sc:Activity>
			<!-- 查询岗位详情 -->
			<sc:Activity id="sub-queryPost" name="查询岗位详情" type="AUTO_TASK">
				<sc:AutoTask>
					<sc:SpringBean beanName="postService" method="getPost"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#postId" target="#id" dataType="long"/>
						<sc:Output source="#result" target="#postDetail"/>
					</sc:DataMapping>
				</sc:AutoTask>
			</sc:Activity>
			<!-- 查询用户详情 -->
			<sc:Activity id="sub-queryUser" name="查询用户详情" type="AUTO_TASK">
				<sc:AutoTask>
					<sc:SpringBean beanName="adminUserService" method="getUser"/>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Input source="#userId" target="#id" dataType="long"/>
						<sc:Output source="#result" target="#userDetail"/>
					</sc:DataMapping>
				</sc:AutoTask>
			</sc:Activity>
			<!-- 子流程结束：构建返回结果 -->
			<sc:Activity id="sub-end" name="子流程结束" type="END_EVENT">
				<sc:EndEvent>
					<sc:DataMapping scope="WORKFLOW">
						<sc:Output source="#postId" target="#subResult.postId"/>
						<sc:Output source="#postDetail" target="#subResult.postDetail"/>
						<sc:Output source="#userId" target="#subResult.userId"/>
						<sc:Output source="#userDetail" target="#subResult.userDetail"/>
					</sc:DataMapping>
				</sc:EndEvent>
			</sc:Activity>
		</sc:Activities>
		<sc:Transitions>
			<sc:Transition id="st-start-SPLIT" from="sub-start" to="sub-SPLIT"/>
			<sc:Transition id="st-SPLIT-createPost" from="sub-SPLIT" to="sub-createPost"/>
			<sc:Transition id="st-SPLIT-createUser" from="sub-SPLIT" to="sub-createUser"/>
			<sc:Transition id="st-createPost-JOIN" from="sub-createPost" to="sub-JOIN"/>
			<sc:Transition id="st-createUser-JOIN" from="sub-createUser" to="sub-JOIN"/>
			<sc:Transition id="st-JOIN-queryPost" from="sub-JOIN" to="sub-queryPost"/>
			<sc:Transition id="st-queryPost-queryUser" from="sub-queryPost" to="sub-queryUser"/>
			<sc:Transition id="st-queryUser-end" from="sub-queryUser" to="sub-end"/>
		</sc:Transitions>
	</sc:Workflow>
</sc:Package>
